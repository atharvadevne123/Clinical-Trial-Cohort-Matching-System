# Clinical Trial Cohort Matching — Environment Variable Reference
# Copy to .env and set your values before running.

# API Configuration
API_KEY=your-secret-api-key-here
DATABASE_URL=postgresql://trialmatch:changeme@localhost:5432/trial_db

# CORS — comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# FHIR Server
FHIR_BASE_URL=http://fhir-server:8080/fhir
# Timeout in seconds for FHIR HTTP requests (default 5.0)
FHIR_TIMEOUT=5.0

# SMTP Configuration (for recruitment emails)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@trial.local
# Timeout in seconds for SMTP connections (default 5)
SMTP_TIMEOUT=5

# Drift Monitoring
# KS-test p-value threshold below which drift is declared (default 0.05)
DRIFT_THRESHOLD=0.05

# Application
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
WORKERS=2

# PostgreSQL (for docker-compose)
POSTGRES_USER=trialmatch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=trial_db
